# Chave da API Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# E-mail que receberá as avaliações enviadas pelo formulário
RESEND_TO_EMAIL=seu-email@dominio.com

# E-mail remetente (deve ser de um domínio verificado no Resend)
# Em desenvolvimento, use: onboarding@resend.dev
RESEND_FROM_EMAIL=noreply@seudominio.com
